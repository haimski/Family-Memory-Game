# Used by vite.config.js (Node context) as the dev-server proxy target for /api/*
API_URL=http://localhost:5000

# Used by client code (import.meta.env.VITE_API_URL in src/api.js). Vite only
# exposes env vars prefixed with VITE_ to the browser bundle, so this must be
# set separately from API_URL above. Leave unset to use relative /api paths
# (works with the dev proxy, or same-domain production deploys).
VITE_API_URL=http://localhost:5000
